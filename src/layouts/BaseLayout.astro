---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** When true, the page renders edge-to-edge with no max-width. Use for retreat detail or map. */
  fullBleed?: boolean;
}

const {
  title,
  description = 'Weekend wellness retreats at private estates across the UK. Cacao, gong, breathwork, sound. Held with intention.',
  ogImage = '/brand/og-default.jpg',
  fullBleed = false,
} = Astro.props;

const pageTitle = title ? `${title} — Kamala Retreats` : 'Kamala Retreats — Rise. Glow. Return.';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://kamalaretreats.com');
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL(ogImage, canonical).toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <meta name="theme-color" content="#f9f3f1" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-ink focus:text-cream focus:px-4 focus:py-2 focus:rounded">Skip to content</a>

    <Header />

    <main id="main" class={fullBleed ? 'flex-1' : 'flex-1 mx-auto w-full max-w-(--container-page) px-6 lg:px-10'}>
      <slot />
    </main>

    <Footer />
    <CookieBanner />
  </body>
</html>
