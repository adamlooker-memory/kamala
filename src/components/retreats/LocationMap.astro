---
/**
 * Small static MapLibre map centred on the retreat venue.
 * Uses OpenFreeMap vector tiles (no API key, free).
 * If lat/lng are missing or zero, renders an attractive textual fallback.
 */
interface Props {
  lat: number | null;
  lng: number | null;
  name: string;
  region?: string | null;
  tbcAddress: boolean;
  address?: string | null;
}

const { lat, lng, name, region, tbcAddress, address } = Astro.props;
const hasCoords = lat !== null && lng !== null && !(lat === 0 && lng === 0);
---

<section class="py-16 lg:py-24 border-t border-sand/60" id="location">
  <div class="grid lg:grid-cols-2 gap-10 items-center">
    <div class="space-y-4">
      <p class="eyebrow">The location</p>
      <h2>{name}</h2>
      {region && <p class="text-ink-soft text-lg leading-relaxed">{region}</p>}
      <p class="text-sm text-ink-soft leading-relaxed">
        {tbcAddress
          ? 'The exact address is shared on booking, to keep the space private for our guests.'
          : address}
      </p>
    </div>
    <div>
      {hasCoords ? (
        <div class="relative w-full h-[380px] rounded-(--radius-card) overflow-hidden border border-sand/70 bg-cream-deep">
          <div data-location-map class="absolute inset-0" data-lat={lat} data-lng={lng}></div>
        </div>
      ) : (
        <div class="aspect-[4/3] rounded-(--radius-card) bg-cream-deep border border-sand/70 flex items-center justify-center text-ink-soft">
          <p class="text-sm">Map shared once your booking is confirmed.</p>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  import 'maplibre-gl/dist/maplibre-gl.css';

  const el = document.querySelector<HTMLElement>('[data-location-map]');
  if (el) {
    const lat = parseFloat(el.dataset.lat ?? '');
    const lng = parseFloat(el.dataset.lng ?? '');
    if (Number.isFinite(lat) && Number.isFinite(lng)) {
      import('maplibre-gl')
        .then((mod) => {
          const maplibregl: any = (mod as any).default;
          const map = new maplibregl.Map({
            container: el,
            style: 'https://tiles.openfreemap.org/styles/positron',
            center: [lng, lat],
            zoom: 9,
            interactive: true,
            attributionControl: { compact: true },
          });
          map.on('error', (e: any) => console.warn('[location-map]', e?.error || e));
          const marker = document.createElement('div');
          marker.style.cssText =
            'width:24px;height:24px;border-radius:9999px;background:#b78f38;border:2px solid #f9f3f1;box-shadow:0 1px 4px rgba(42,38,34,0.3)';
          new maplibregl.Marker({ element: marker }).setLngLat([lng, lat]).addTo(map);
        })
        .catch((err) => {
          console.error('[location-map] failed to load maplibre-gl', err);
        });
    }
  }
</script>

<style>
  :global(.maplibregl-canvas) { outline: none; }
  :global(.maplibregl-ctrl-attrib) { font-size: 10px; }
</style>
