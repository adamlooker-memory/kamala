---
interface Props {
  ratio?: '1/1' | '3/2' | '2/3' | '4/5' | '3/4' | '16/9' | '21/9';
  label?: string;
  class?: string;
}

const { ratio = '3/2', label, class: className = '' } = Astro.props;

const ratioMap: Record<string, string> = {
  '1/1':  'aspect-square',
  '3/2':  'aspect-[3/2]',
  '2/3':  'aspect-[2/3]',
  '4/5':  'aspect-[4/5]',
  '3/4':  'aspect-[3/4]',
  '16/9': 'aspect-[16/9]',
  '21/9': 'aspect-[21/9]',
};
---

<div
  class:list={[
    'relative w-full overflow-hidden rounded-(--radius-card) bg-cream-deep border border-sand/70',
    ratioMap[ratio],
    className,
  ]}
  aria-hidden="true"
>
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="absolute inset-0 opacity-40" style="background-image: linear-gradient(135deg, transparent 49%, rgba(183,143,56,0.18) 49.5%, rgba(183,143,56,0.18) 50.5%, transparent 51%); background-size: 24px 24px;"></div>
    <div class="relative z-10 flex flex-col items-center gap-3 text-center px-6">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#b78f38" stroke-width="1" aria-hidden="true">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 7c-2 2-3 3-3 5 0 1.5 1.5 3 3 3s3-1.5 3-3c0-2-1-3-3-5z" />
      </svg>
      {label ? (
        <span class="text-[0.65rem] uppercase tracking-[0.22em] text-gold-700/80">{label}</span>
      ) : (
        <span class="text-[0.65rem] uppercase tracking-[0.22em] text-gold-700/60">Image</span>
      )}
    </div>
  </div>
</div>
